function showTogglePanelAndApply() {
	var toggles = [
		"T_Shadow",
		"T_Overall_Glow",
		"T_Rimlight",
		"T_Mood",
		"T_Outline"
	];

	var myDialog = new Dialog();
	myDialog.title = "Toggle Effects";

	// Store checkboxes for later access
	var checkboxes = {};

	// Get the first selected node to read current toggle states
	var firstSelectedNode = selection.selectedNode(0);
	if (!firstSelectedNode) {
		MessageLog.trace("No node selected");
		return;
	}

	// Read current transparency values to determine checkbox states
	var lightBox = new LightingController(firstSelectedNode);
	var currentFrame = frame.current();

	toggles.forEach(function (toggle) {
		var cb = new CheckBox();
		cb.text = toggle;
		
		// Default to true if we can't read the value
		var isEnabled = true;
		
		try {
			// Use the new getEffectState method from PropertyController
			isEnabled = lightBox.getEffectState(toggle, currentFrame);
		} catch (e) {
			MessageLog.trace("Error reading toggle state for " + toggle + ": " + e.toString());
		}
		
		cb.checked = isEnabled;
		myDialog.add(cb);
		checkboxes[toggle] = cb;
	});

	if (myDialog.exec()) {
		// Get frame range
		var startFrame = selection.startFrame();
		var endFrame = startFrame + selection.numberOfFrames() - 1;

		// Build enabled list from checked boxes
		var enabledList = [];
		toggles.forEach(function (toggle) {
			if (checkboxes[toggle].checked) {
				enabledList.push(toggle);
			}
		});

		// Apply to each selected node
		var numNodes = selection.numberOfNodesSelected();
		for (var i = 0; i < numNodes; i++) {
			var nodeName = selection.selectedNode(i);
			var lightBox = new LightingController(nodeName);
			lightBox.ToggleEffects(startFrame, endFrame, enabledList);
		}

		MessageLog.trace("Applied toggles: " + JSON.stringify(enabledList) + " to " + numNodes + " nodes");
	} else {
		MessageLog.trace("Toggle panel cancelled.");
	}
}

