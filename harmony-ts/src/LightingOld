
/**
 * Generic property controller for managing layer attributes (transparency, intensity, etc.)
 * Handles both reading and writing property values across frame ranges
 */
class PropertyController {
	layer: any;
	attributeName: string;
	enabledValue: string;
	disabledValue: string;
	isInverted: boolean; // For properties like Intensity where high = enabled (opposite of transparency)

	/**
	 * @param layer - The layer object containing the property
	 * @param attributeName - Name of the column/attribute (e.g., "TRANSPARENCY", "Intensity")
	 * @param enabledValue - Value when property is enabled (e.g., "0" for transparency, "100" for intensity)
	 * @param disabledValue - Value when property is disabled (e.g., "100" for transparency, "0" for intensity)
	 * @param isInverted - Whether the property is inverted (true for intensity-based properties)
	 */
	constructor(layer: any, attributeName: string, enabledValue: string, disabledValue: string, isInverted: boolean = false) {
		this.layer = layer;
		this.attributeName = attributeName;
		this.enabledValue = enabledValue;
		this.disabledValue = disabledValue;
		this.isInverted = isInverted;
	}

	/**
	 * Get the column for this property
	 */
	getColumn(): any {
		const col = this.layer.getColumn(this.attributeName);
		if (!col) {
			throw new Error(this.attributeName + " column not found in layer: " + this.layer.name);
		}
		return col;
	}

	/**
	 * Check if the property is enabled at a specific frame
	 * @param frameNumber - Frame number to check
	 * @returns true if enabled, false if disabled
	 */
	isEnabled(frameNumber: number): boolean {
		const col = this.getColumn();
		const value = col.getKeyframe(frameNumber);
		const numValue = parseFloat(value);
		const enabledNumValue = parseFloat(this.enabledValue);
		const disabledNumValue = parseFloat(this.disabledValue);
		
		// If values are closer to enabled value, consider it enabled
		const midpoint = (enabledNumValue + disabledNumValue) / 2;
		return numValue >= midpoint;
	}

	/**
	 * Enable the property for a frame range
	 * @param start - Start frame
	 * @param end - End frame
	 */
	enable(start: number, end: number): void {
		const col = this.getColumn();
		const status = col.setKeyframeRange(start, end, this.enabledValue);
		if (!status) {
			throw new Error("Failed to enable " + this.attributeName + " on layer: " + this.layer.name);
		}
		MessageLog.trace("✅ Enabled " + this.attributeName + " on layer '" + this.layer.name + "' from frame " + start + " to " + end);
	}

	/**
	 * Disable the property for a frame range
	 * @param start - Start frame
	 * @param end - End frame
	 */
	disable(start: number, end: number): void {
		const col = this.getColumn();
		const status = col.setKeyframeRange(start, end, this.disabledValue);
		if (!status) {
			throw new Error("Failed to disable " + this.attributeName + " on layer: " + this.layer.name);
		}
		MessageLog.trace("❌ Disabled " + this.attributeName + " on layer '" + this.layer.name + "' from frame " + start + " to " + end);
	}

	/**
	 * Set the property state for a frame range
	 * @param start - Start frame
	 * @param end - End frame
	 * @param enabled - true to enable, false to disable
	 */
	setState(start: number, end: number, enabled: boolean): void {
		if (enabled) {
			this.enable(start, end);
		} else {
			this.disable(start, end);
		}
	}

	/**
	 * Factory method to create a PropertyController for transparency-based properties
	 */
	static forTransparency(layer: any): PropertyController {
		return new PropertyController(layer, "TRANSPARENCY", "0", "100", false);
	}

	/**
	 * Factory method to create a PropertyController for intensity-based properties
	 */
	static forIntensity(layer: any): PropertyController {
		return new PropertyController(layer, "Intensity", "100", "0", true);
	}
}

class LightingController {
	static TOGGLES: string[] = [
		"T_Mood",
		"T_Rimlight",
		"T_Shadow",
		"T_Outline",
		"T_Overall_Glow"
	];

	name: string;
	index: number;
	associatedEffects: any;
	toggles: { [key: string]: any };
	propertyControllers: { [key: string]: PropertyController };
	glow: any;
	outsideGlowLayer: any;
	glowLeft: any = null;
	glowRight: any = null;
	controllers: { glowLeft: any; glowRight: any; outsideGlow: any };

	constructor(drawingLayerName: string) {

		const afterUnderscore = (str: string): string => {
			const idx = str.indexOf("_");
			return idx !== -1 ? str.substring(idx + 1) : "";
		};

		this.name = drawingLayerName;
		this.index = Number(afterUnderscore(drawingLayerName));

		const layer = layerManager.getNodeLayer(drawingLayerName);

		this.associatedEffects = layerManager.getNodeLayer("Top/Effects_" + this.index);
		MessageLog.trace("Associated effects layer: " + this.associatedEffects);
		const children = this.associatedEffects.getChildren();
		const togglesArray = filterArray(children, (child: any) => {
			if (child) {
				return child.name.indexOf("T_") === 0;
			}
			return false;
		});
		this.toggles = {};
		this.propertyControllers = {};
		
		togglesArray.forEach((toggle: any) => {
			this.toggles[toggle.name] = toggle;
			// Create PropertyController for each toggle (they use transparency)
			this.propertyControllers[toggle.name] = PropertyController.forTransparency(toggle);
			MessageLog.trace("✅ " + toggle.name);
		});

		children.forEach((child: any) => {
			if (child && child.name === "Outside_Glow") 
				this.outsideGlowLayer = child;
			if (child && child.name === "Glow") 
				this.glow = child;
		});

		stringify(this.glow);
		if (this.glow) {
			const glowChildren = this.glow.getChildren();
			glowChildren.forEach((child: any) => {
				if (child && child.name === "Glow_Left") 
					this.glowLeft = child;
				if (child && child.name === "Glow_Right") 
					this.glowRight = child;
			});
		}
		
		// Create PropertyControllers for intensity-based effects
		if (this.outsideGlowLayer) {
			this.propertyControllers["Outside_Glow"] = PropertyController.forIntensity(this.outsideGlowLayer);
		}
		if (this.glowLeft) {
			this.propertyControllers["Glow_Left"] = PropertyController.forIntensity(this.glowLeft);
		}
		if (this.glowRight) {
			this.propertyControllers["Glow_Right"] = PropertyController.forIntensity(this.glowRight);
		}
		
		this.controllers = {
			glowLeft: this.glowLeft,
			glowRight: this.glowRight,
			outsideGlow: this.outsideGlowLayer
		};

		stringify(this.controllers.glowLeft.getAttributeNames());
	}

	/**
	 * Get the enabled state of an effect at a specific frame
	 * @param effectName - Name of the effect (e.g., "T_Shadow", "Outside_Glow")
	 * @param frameNumber - Frame number to check
	 * @returns true if enabled, false if disabled
	 */
	getEffectState(effectName: string, frameNumber: number): boolean {
		const controller = this.propertyControllers[effectName];
		if (!controller) {
			throw new Error("Property controller not found for: " + effectName);
		}
		return controller.isEnabled(frameNumber);
	}

	/**
	 * Set an effect's enabled/disabled state for a frame range
	 * @param effectName - Name of the effect (e.g., "T_Shadow", "Outside_Glow")
	 * @param start - Start frame
	 * @param end - End frame
	 * @param enabled - true to enable, false to disable
	 */
	setEffect(effectName: string, start: number, end: number, enabled: boolean): void {
		const controller = this.propertyControllers[effectName];
		if (!controller) {
			throw new Error("Property controller not found for: " + effectName);
		}
		controller.setState(start, end, enabled);
	}

	/**
	 * Legacy method - uses new setEffect internally
	 */
	setToggle(toggleName: string, start: number, end: number, enabled: boolean): void {
		this.setEffect(toggleName, start, end, enabled);
	}

	ToggleAll(start: number, end: number, enabled: boolean): void {
		for (const toggleName of LightingController.TOGGLES) {
			this.setToggle(toggleName, start, end, enabled);
		}
	}

	ToggleEffects(start: number, end: number, enabledEffectsList: string[]): void {
		for (const toggleName of LightingController.TOGGLES) {
			const enabled = (enabledEffectsList.indexOf(toggleName) !== -1);
			this.setToggle(toggleName, start, end, enabled);
		}
	}
}

