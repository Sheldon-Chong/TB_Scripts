function showLightingControllerUI() {
	// Load the UI file using UiLoader
	var ui = UiLoader.load("c:/Users/emers/AppData/Roaming/Toon Boom Animation/Toon Boom Harmony Premium/2400-scripts/lighting_controller.ui");
	
	if (!ui) {
		MessageBox.warning("Failed to load lighting_controller.ui");
		return;
	}

	// Get the first selected node
	var firstSelectedNode = selection.selectedNode(0);
	if (!firstSelectedNode) {
		MessageBox.warning("No node selected");
		return;
	}

	// Create the LightingController instance
	var lightBox = new LightingController(firstSelectedNode);
	var currentFrame = frame.current();

	// Map UI control names to effect names and their controllers
	var effectMapping = {
		"mood": "T_Mood",
		"shadow": "T_Shadow",
		"rimlight": "T_Rimlight",
		"outline": "T_Outline",
		"glow": "T_Overall_Glow"  // Uses transparency, not Outside_Glow
	};

	// Helper function to find widget by objectName in children recursively
	function findWidgetByName(parent, name) {
		if (!parent || !parent.children) return null;
		
		var children = parent.children();
		for (var i = 0; i < children.length; i++) {
			var child = children[i];
			if (child.objectName === name) {
				return child;
			}
			// Recursively search in children
			var found = findWidgetByName(child, name);
			if (found) return found;
		}
		return null;
	}
	
	// Set initial values from current frame state
	for (var controlName in effectMapping) {
		var effectName = effectMapping[controlName];
		
		// Find widgets by their objectName
		var checkbox = findWidgetByName(ui, controlName + "_checkbox");
		var slider = findWidgetByName(ui, controlName + "_slider");
		var spinbox = findWidgetByName(ui, controlName + "_spinbox");
		
		MessageLog.trace("Setting up " + controlName + " - checkbox: " + (checkbox ? "found" : "NOT FOUND") + 
						 ", slider: " + (slider ? "found" : "NOT FOUND") + 
						 ", spinbox: " + (spinbox ? "found" : "NOT FOUND"));
		
		if (!checkbox || !slider || !spinbox) {
			MessageLog.trace("WARNING: Could not find widgets for " + controlName);
			continue;
		}
		
		try {
			// Set slider/spinbox ranges FIRST (0-100 for intensity/transparency)
			// Use the correct property names
			slider["minimum"] = 0;
			slider["maximum"] = 100;
			spinbox["minimum"] = 0;
			spinbox["maximum"] = 100;
			
			MessageLog.trace("Set ranges for " + controlName);
			
			// Get the actual transparency/intensity value from the column
			var propController = lightBox.propertyControllers[effectName];
			if (!propController) {
				MessageLog.trace("No property controller for " + effectName);
				continue;
			}
			
			var col = propController.getColumn();
			var rawValue = parseFloat(col.getKeyframe(currentFrame));
			
			// Convert raw value to user-facing value (0-100 where 100 = fully visible)
			// For transparency: raw 0 = visible, raw 100 = invisible, so invert it
			// For intensity: raw 100 = visible, raw 0 = invisible, so keep it
			var displayValue = propController.isInverted ? rawValue : (100 - rawValue);
			
			// Set checkbox based on whether it's enabled (using midpoint logic)
			var isEnabled = lightBox.getEffectState(effectName, currentFrame);
			checkbox.checked = isEnabled;
			
			// Set slider/spinbox to the user-facing value
			slider["value"] = displayValue;
			spinbox["value"] = displayValue;
			
			MessageLog.trace("Set " + controlName + " - raw value: " + rawValue + ", display value: " + displayValue + " (enabled: " + isEnabled + ")");
			
		} catch (e) {
			MessageLog.trace("Error setting up " + effectName + ": " + e.toString());
		}
	}



	// Connect sliders to spinboxes (keep them synchronized)
	for (var controlName in effectMapping) {
		(function(ctrlName) {
			MessageLog.trace("Setting up connections for: " + ctrlName);

			// Find widgets using the helper function
			var slider = findWidgetByName(ui, ctrlName + "_slider");
			var spinbox = findWidgetByName(ui, ctrlName + "_spinbox");
			var checkbox = findWidgetByName(ui, ctrlName + "_checkbox");
			
			if (!slider || !spinbox || !checkbox) {
				MessageLog.trace("WARNING: Cannot connect signals for " + ctrlName + " - widgets not found");
				return;
			}
			
			// When slider changes, update spinbox
			slider["valueChanged"].connect(function(value) {
				spinbox["value"] = value;
				// Auto-check checkbox when value > 0
				checkbox["checked"] = (value > 0);
			});
			
			// When spinbox changes, update slider
			spinbox["valueChanged"].connect(function(value) {
				slider["value"] = value;
				// Auto-check checkbox when value > 0
				checkbox["checked"] = (value > 0);
			});
			
			// When checkbox changes, enable/disable controls
			checkbox["toggled"].connect(function(checked) {
				slider["enabled"] = checked;
				spinbox["enabled"] = checked;
				if (!checked) {
					slider["value"] = 0;
					spinbox["value"] = 0;
				} else if (slider["value"] === 0) {
					slider["value"] = 100;
					spinbox["value"] = 100;
				}
			});
		})(controlName);
	}

	// Connect the OK button to apply values
	var buttonBox = findWidgetByName(ui, "buttonBox");
	if (buttonBox) {
		buttonBox["accepted"].connect(function() {
			MessageLog.trace("=== OK Button Clicked ===");
			
			// Wrap everything in an undo/redo accumulator
			scene.beginUndoRedoAccum("Apply Lighting Effects");
			
			try {
				// Get frame range from selection
				var startFrame = selection.startFrame();
				var endFrame = startFrame + selection.numberOfFrames() - 1;
				
				MessageLog.trace("Frame range: " + startFrame + " to " + endFrame);
				
				// Apply to each selected node
				var numNodes = selection.numberOfNodesSelected();
				MessageLog.trace("Number of selected nodes: " + numNodes);
				
				for (var i = 0; i < numNodes; i++) {
					var nodeName = selection.selectedNode(i);
					MessageLog.trace("Processing node: " + nodeName);
					
					var controller = new LightingController(nodeName);
					
					for (var controlName in effectMapping) {
						var effectName = effectMapping[controlName];
						var checkbox = findWidgetByName(ui, controlName + "_checkbox");
						var spinbox = findWidgetByName(ui, controlName + "_spinbox");
					
						if (!checkbox || !spinbox) {
							MessageLog.trace("Skipping " + controlName + " - widgets not found");
							continue;
						}
						
						var isChecked = checkbox["checked"];
						var spinValue = spinbox["value"];
						
						MessageLog.trace(controlName + ": checked=" + isChecked + ", value=" + spinValue);
						
						if (isChecked && spinValue > 0) {
							// Apply the spinbox value directly
							var propController = controller.propertyControllers[effectName];
							
							if (propController) {
								var col = propController.getColumn();
								
								// For transparency-based: lower value = more visible
								// For intensity-based: higher value = more visible
								var valueToSet = propController.isInverted ? spinValue.toString() : (100 - spinValue).toString();
								
								MessageLog.trace("Setting " + effectName + " column to value: " + valueToSet);
								var success = col.setKeyframeRange(startFrame, endFrame, valueToSet);
								MessageLog.trace("setKeyframeRange returned: " + success);
							}
						} else {
							// Disable the effect (set to disabled value)
							MessageLog.trace("Disabling " + effectName);
							controller.setEffect(effectName, startFrame, endFrame, false);
						}
					}
				}
				
				MessageLog.trace("Applied lighting settings to " + numNodes + " node(s)");
			} catch (e) {
				MessageLog.trace("ERROR in OK button handler: " + e.toString());
			} finally {
				scene.endUndoRedoAccum();
			}
		});
	}

	// Show the dialog
	if (ui.exec()) {
		MessageLog.trace("Lighting settings applied");
	} else {
		MessageLog.trace("Cancelled");
	}
}